# Copy this file to .env and fill in your values.

# Gemini API key (required for real AI analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Set to true for demo mode (fast, no API calls needed)
# Set to false to run full real AI pipeline
USE_MOCKS=true

# Only used when USE_MOCKS=true:
#   canned  -> fixed 6-issue demo data (deterministic)
#   cuad    -> reads the real uploaded file
PIPELINE_SOURCE=canned

# Gemini model override (default: gemini-1.5-flash-latest)
# GEMINI_MODEL=gemini-1.5-flash-latest
